generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  body        String
  category    Category
  priority    Priority @default(Normal)
  publishDate DateTime
  imageUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Category {
  Exam
  Event
  General
}

enum Priority {
  Normal
  Urgent
}
